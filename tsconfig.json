{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "orchestrator/**/*.ts",
    "logger/**/*.ts",
    "context_engine/**/*.ts",
    "insight_engine/**/*.ts",
    "extension/**/*.ts",
    "pi_agent/**/*.ts",
    "shared/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
