{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "core/**/*.ts",
    "knowledge/engine/**/*.ts",
    "knowledge/markdown/**/*.ts",
    "agents/**/*.ts",
    "automation/**/*.ts",
    "entry/**/*.ts",
    "logger/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
