# ObsidiClaw example environment file (copy to `.env` and fill in values).
#
# Keep secrets out of git. `.env` is ignored by default.

# Embeddings (default: Ollama)
OBSIDI_EMBED_PROVIDER=ollama
OBSIDI_EMBED_HOST=http://localhost:11434
OBSIDI_EMBED_MODEL=nomic-embed-text:latest
OBSIDI_EMBED_CONTEXT_LENGTH=512

# LLM (default: Ollama)
OBSIDI_LLM_PROVIDER=ollama
OBSIDI_LLM_HOST=http://localhost:11434
OBSIDI_LLM_MODEL=cogito:8b
OBSIDI_LLM_CONTEXT_WINDOW=32768
OBSIDI_LLM_MAX_TOKENS=4096

# If using OpenAI providers
# OPENAI_API_KEY=

# Optional web search tool for Pi extension
# PERPLEXITY_API_KEY=

# Debug logging
# OBSIDI_CLAW_DEBUG=0

# Optional: disable context review/synthesis (prevents LLM calls during retrieval)
# Useful for CI / offline smoke tests.
# OBSIDI_CONTEXT_REVIEW=0
